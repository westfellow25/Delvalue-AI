# === DelValue AI v2.0 Configuration ===

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///data/delvalue.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/delvalue

# Auth
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# AI / LLM (optional — system works without, used for narrative generation)
ANTHROPIC_API_KEY=your_api_key_here
DEFAULT_MODEL=claude-sonnet-4-20250514

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ML
ML_MODEL_DIR=data/ml_models
MONTE_CARLO_ITERATIONS=10000

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_ANALYSIS_PER_HOUR=100
